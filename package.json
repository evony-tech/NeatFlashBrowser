{
  "name": "NeatFlashBrowser",
  "productName": "NeatFlashBrowser",
  "description": "Browser For Flash Player Games",
  "homepage": "http://neato3.com/neatflashbrowser",
  "author": "Evony-Tech",
  "version": "1.3.5",
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "publish": "electron-builder --win -p always",
    "build": "electron-builder --win",
    "build1": "electron-packager . FlashBrowser --platform=darwin --overwrite --icon=icon.icns",
    "build2": "electron-packager . FlashBrowser --platform=win32 --overwrite --icon=icon.ico",
    "build3": "electron-packager . FlashBrowser --all --overwrite --icon=icon.ico",
    "build4": "electron-packager . FlashBrowser --all --overwrite --icon=icon.ico",
    "buildWin32": "electron-packager . FlashBrowser --platform=win32 --arch=ia32 --overwrite --icon=icon.ico --production --prune -p always",
    "buildWin64": "electron-packager . FlashBrowser --platform=win32 --overwrite --icon=icon.ico -p always --prune-license nm-prune --force"
  },
  "license": "ISC",
  "engines": {
    "node": ">=12.14.0"
  },
  "devDependencies": {
    "electron": "^9.4.4",
    "electron-builder": "^22.14.13",
    "electron-packager": "^15.5.2"
  },
  "dependencies": {
    "electron-context-menu": "^3.6.1",
    "electron-find": "^1.0.7",
    "electron-navigation": "^6.6.6",
    "electron-version": "^2.0.1",
    "resolve-dependencies": "^6.0.9"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/evony-tech/NeatFlashBrowser.git"
  },
  "build": {
    "appId": "com.neato3.neatflashbrowser",
    "asarUnpack": [
      "flashver/**/*"
    ],
    "protocols": [
      {
        "name": "HTTP Protocol",
        "schemes": [
          "http"
        ]
      }
    ],
    "fileAssociations": [
      {
        "ext": [
          "htm",
          "html"
        ],
        "name": "HTML Document"
      }
    ],
    "win": {
      "executableName": "NeatFlashBrowser",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ]
    },
    "nsis": {
      "include": "installer.nsh",
      "menuCategory": "NeatFlashBrowser",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "uninstallDisplayName": "NeatFlashBrowser",
      "oneClick": true,
      "perMachine": false,
      "artifactName": "NeatFlashBrowser-Setup.${ext}"
    }
  }
}
